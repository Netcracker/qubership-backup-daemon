{
  "info": {
    "name": "Backup Daemon BWC Tests",
    "description": "Backward compatibility tests for the Qubership Backup Daemon HTTP API.\nValidates response structure, status codes, and content types to ensure API contract stability during the Go rewrite.\nReference: current Python implementation is the source of truth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{username}}", "type": "string" },
      { "key": "password", "value": "{{password}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "backup_id", "value": "" },
    { "key": "task_id", "value": "" },
    { "key": "poll_retries", "value": "0" }
  ],
  "item": [
    {
      "name": "BWC: GET /health",
      "item": [
        {
          "name": "GET /health — returns health JSON for full storage",
          "request": { "method": "GET", "url": "{{base_url}}/health", "auth": { "type": "noauth" } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('BWC: GET /health returns HTTP 200', function () {",
            "    pm.response.to.have.status(200);",
            "});",
            "pm.test('BWC: GET /health Content-Type is application/json', function () {",
            "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
            "});",
            "pm.test('BWC: GET /health body has required field \"status\" (UP|Warning)', function () {",
            "    var json = pm.response.json();",
            "    pm.expect(json).to.have.property('status');",
            "    pm.expect(json.status).to.be.oneOf(['UP', 'Warning']);",
            "});",
            "pm.test('BWC: GET /health body has required field \"storage\" with \"dump_count\"', function () {",
            "    var s = pm.response.json().storage;",
            "    pm.expect(s).to.be.an('object');",
            "    pm.expect(s.dump_count).to.be.a('number');",
            "});",
            "pm.test('BWC: GET /health body has required field \"backup_queue_size\" (number)', function () {",
            "    pm.expect(pm.response.json().backup_queue_size).to.be.a('number');",
            "});",
            "pm.test('BWC: GET /health storage has filesystem fields (non-S3 mode)', function () {",
            "    var s = pm.response.json().storage;",
            "    if (s.hasOwnProperty('size')) {",
            "        pm.expect(s.size).to.be.a('number');",
            "        pm.expect(s.free_space).to.be.a('number');",
            "        pm.expect(s.total_space).to.be.a('number');",
            "        pm.expect(s.free_inodes).to.be.a('number');",
            "        pm.expect(s.total_inodes).to.be.a('number');",
            "        pm.expect(s.used_inodes).to.be.a('number');",
            "    }",
            "});",
            "pm.test('BWC: GET /health storage.lastSuccessful has VaultInfo schema when present', function () {",
            "    var s = pm.response.json().storage;",
            "    if (s.lastSuccessful) {",
            "        var v = s.lastSuccessful;",
            "        pm.expect(v.id).to.be.a('string');",
            "        pm.expect(v.failed).to.be.a('boolean');",
            "        pm.expect(v.locked).to.be.a('boolean');",
            "        pm.expect(v.sharded).to.be.a('boolean');",
            "        pm.expect(v.canceled).to.be.a('boolean');",
            "        pm.expect(v.ts).to.be.a('number');",
            "        pm.expect(v.metrics).to.be.an('object');",
            "    }",
            "});",
            "pm.test('BWC: GET /health storage.last has VaultInfo schema when present', function () {",
            "    var s = pm.response.json().storage;",
            "    if (s.last) {",
            "        var v = s.last;",
            "        pm.expect(v.id).to.be.a('string');",
            "        pm.expect(v.failed).to.be.a('boolean');",
            "        pm.expect(v.locked).to.be.a('boolean');",
            "        pm.expect(v.ts).to.be.a('number');",
            "        pm.expect(v.metrics).to.be.an('object');",
            "    }",
            "});"
          ] } }]
        },
        {
          "name": "GET /health/prometheus — returns Prometheus text metrics",
          "request": { "method": "GET", "url": "{{base_url}}/health/prometheus", "auth": { "type": "noauth" } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('BWC: GET /health/prometheus returns HTTP 200', function () {",
            "    pm.response.to.have.status(200);",
            "});",
            "pm.test('BWC: GET /health/prometheus body is non-empty text', function () {",
            "    pm.expect(pm.response.text().length).to.be.above(0);",
            "});",
            "pm.test('BWC: GET /health/prometheus contains backup_daemon_status metric', function () {",
            "    pm.expect(pm.response.text()).to.include('backup_daemon_status');",
            "});",
            "pm.test('BWC: GET /health/prometheus contains backup_storage_dump_count metric', function () {",
            "    pm.expect(pm.response.text()).to.include('backup_storage_dump_count');",
            "});"
          ] } }]
        },
        {
          "name": "GET /incremental/health — returns 500 when incremental is not configured",
          "request": { "method": "GET", "url": "{{base_url}}/incremental/health", "auth": { "type": "noauth" } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('BWC: GET /incremental/health returns HTTP 200 or 500', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([200, 500]);",
            "});",
            "if (pm.response.code === 200) {",
            "    pm.test('BWC: GET /incremental/health body has health structure', function () {",
            "        var j = pm.response.json();",
            "        pm.expect(j).to.have.property('status');",
            "        pm.expect(j).to.have.property('storage');",
            "        pm.expect(j).to.have.property('backup_queue_size');",
            "    });",
            "}"
          ] } }]
        }
      ]
    },
    {
      "name": "BWC: POST /backup",
      "item": [
        {
          "name": "POST /backup — without body triggers full backup",
          "request": { "method": "POST", "url": "{{base_url}}/backup" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('BWC: POST /backup (no body) returns HTTP 200', function () {",
            "    pm.response.to.have.status(200);",
            "});",
            "pm.test('BWC: POST /backup (no body) Content-Type is application/json', function () {",
