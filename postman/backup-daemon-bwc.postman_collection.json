    {
      "name": "BWC: GET /jobstatus",
      "item": [
        {
          "name": "GET /jobstatus/:task_id — returns job status structure",
          "request": { "method": "GET", "url": "{{base_url}}/jobstatus/{{task_id}}" },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "if (!pm.collectionVariables.get('task_id')) pm.execution.skipRequest();"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('BWC: GET /jobstatus/:id returns HTTP 200 or 206', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 206]);",
              "});",
              "pm.test('BWC: GET /jobstatus/:id Content-Type is application/json', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "pm.test('BWC: GET /jobstatus/:id body has field \"task_id\" (string)', function () {",
              "    pm.expect(pm.response.json().task_id).to.be.a('string');",
              "});",
              "pm.test('BWC: GET /jobstatus/:id body has field \"type\" (string)', function () {",
              "    pm.expect(pm.response.json().type).to.be.a('string');",
              "});",
              "pm.test('BWC: GET /jobstatus/:id body has field \"status\" (Successful|Queued|Processing|Failed)', function () {",
              "    pm.expect(pm.response.json().status).to.be.oneOf(['Successful','Queued','Processing','Failed']);",
              "});",
              "pm.test('BWC: GET /jobstatus/:id body has field \"vault\"', function () {",
              "    pm.expect(pm.response.json()).to.have.property('vault');",
              "});",
              "pm.test('BWC: GET /jobstatus/:id body has field \"err\"', function () {",
              "    pm.expect(pm.response.json()).to.have.property('err');",
              "});"
            ] } }
          ]
        },
        {
          "name": "Poll /jobstatus until backup completes",
          "request": { "method": "GET", "url": "{{base_url}}/jobstatus/{{task_id}}" },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "if (!pm.collectionVariables.get('task_id')) pm.execution.skipRequest();"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "if (pm.response.code === 206) {",
              "    var r = parseInt(pm.collectionVariables.get('poll_retries') || '0') + 1;",
              "    pm.collectionVariables.set('poll_retries', r.toString());",
              "    if (r < 120) { postman.setNextRequest('Poll /jobstatus until backup completes'); }",
              "    else { pm.test('BWC: backup completed within timeout', function(){ pm.expect.fail('timeout after '+r+' polls'); }); }",
              "} else {",
              "    pm.collectionVariables.set('poll_retries', '0');",
              "    pm.test('BWC: GET /jobstatus final status is HTTP 200 (Successful) or 500 (Failed)', function () {",
              "        pm.expect(pm.response.code).to.be.oneOf([200, 500]);",
              "    });",
              "}"
            ] } }
          ]
        },
        {
          "name": "GET /jobstatus/:unknown — returns 404 or 500 with error",
          "request": { "method": "GET", "url": "{{base_url}}/jobstatus/unknown-task-99999" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('BWC: GET /jobstatus/unknown returns HTTP 404 or 500', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([404, 500]);",
            "});",
            "pm.test('BWC: GET /jobstatus/unknown Content-Type is application/json', function () {",
            "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
            "});",
            "pm.test('BWC: GET /jobstatus/unknown body has field \"message\" (string)', function () {",
            "    pm.expect(pm.response.json().message).to.be.a('string');",
            "});"
          ] } }]
        }
      ]
    },
