    {
      "name": "BWC: GET /find",
      "item": [
        {
          "name": "GET /find — via sendRequest (GET+body): ts=0 → 200, future ts → 404",
          "request": { "method": "GET", "url": "{{base_url}}/health", "auth": { "type": "noauth" } },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "var baseUrl = pm.variables.get('base_url');",
              "pm.sendRequest({ url: baseUrl+'/find', method:'GET',",
              "    header:{'Content-Type':'application/json'},",
              "    body:{mode:'raw',raw:JSON.stringify({ts:'0'})}",
              "}, function(err,res){",
              "    pm.collectionVariables.set('find_ok_code', res.code);",
              "    pm.collectionVariables.set('find_ok_body', res.text());",
              "});",
              "pm.sendRequest({ url: baseUrl+'/find', method:'GET',",
              "    header:{'Content-Type':'application/json'},",
              "    body:{mode:'raw',raw:JSON.stringify({ts:'99999999999999999'})}",
              "}, function(err,res){",
